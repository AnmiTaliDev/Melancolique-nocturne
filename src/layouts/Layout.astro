import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A curated color palette evoking the atmosphere of a pensive night.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
