---
// SPDX-FileCopyrightText: AnmiTaliDev <anmitalidev@nuros.org>
// SPDX-License-Identifier: AGPL-3.0-only
import Layout from '../layouts/Layout.astro';
import ColorCard from '../components/ColorCard.astro';
import UsageCard from '../components/UsageCard.astro';

const colors = [
  {
    name: "Midnight Shadow",
    hex: "#1a1a2e",
    rgb: "26, 26, 46",
    description: "Deep navy — the sky at its darkest hour before dawn",
  },
  {
    name: "Deep Indigo",
    hex: "#16213e",
    rgb: "22, 33, 62",
    description: "Rich indigo evoking the infinite depth of the night sky",
  },
  {
    name: "Melancholy Blue",
    hex: "#4a5d7a",
    rgb: "74, 93, 122",
    description: "Muted blue carrying the quiet weight of contemplation",
  },
  {
    name: "Moonlit Gray",
    hex: "#6b7b95",
    rgb: "107, 123, 149",
    description: "The blue-gray hue of moonlight diffused through clouds",
  },
  {
    name: "Catharsis",
    hex: "#9bb5d6",
    rgb: "155, 181, 214",
    description: "A liberating blue — the moment of clarity after sorrow",
  },
  {
    name: "Distant Stars",
    hex: "#d4e4f0",
    rgb: "212, 228, 240",
    description: "The ghostly light of unreachable constellations in endless dark",
  },
];

const usages = [
  {
    title: "Web Design",
    description:
      "Atmospheric websites, music and art blogs, creative portfolios, literary and poetic platforms.",
  },
  {
    title: "UI / UX",
    description:
      "Dark-mode application themes, meditative wellness apps, music players, and reading interfaces.",
  },
  {
    title: "Graphic Design",
    description:
      "Melancholic posters, album and book covers, fine art prints, and editorial illustrations.",
  },
  {
    title: "Interior Design",
    description:
      "Bedrooms and retreat spaces, home libraries, intimate cafes, art galleries.",
  },
];

const snippets = {
  css: `:root {
  --midnight-shadow: #1a1a2e;
  --deep-indigo:     #16213e;
  --melancholy-blue: #4a5d7a;
  --moonlit-gray:    #6b7b95;
  --catharsis:       #9bb5d6;
  --distant-stars:   #d4e4f0;
}`,
  scss: `$midnight-shadow: #1a1a2e;
$deep-indigo:     #16213e;
$melancholy-blue: #4a5d7a;
$moonlit-gray:    #6b7b95;
$catharsis:       #9bb5d6;
$distant-stars:   #d4e4f0;`,
  tailwind: `// tailwind.config.js
module.exports = {
  theme: {
    extend: {
      colors: {
        'midnight-shadow': '#1a1a2e',
        'deep-indigo':     '#16213e',
        'melancholy-blue': '#4a5d7a',
        'moonlit-gray':    '#6b7b95',
        'catharsis':       '#9bb5d6',
        'distant-stars':   '#d4e4f0',
      },
    },
  },
};`,
};
---

<Layout title="Mélancolique Nocturne — Color Palette">
  <nav class="nav">
    <ul class="nav-links">
      <li><a href="#palette">Palette</a></li>
      <li><a href="#usage">Usage</a></li>
      <li><a href="#code">Code</a></li>
    </ul>
  </nav>

  <header class="hero">
    <div class="hero-inner">
      <p class="hero-label">Color Palette</p>
      <h1 class="hero-title">
        Mélancolique<br />Nocturne
      </h1>
      <p class="hero-desc">
        Six carefully composed shades tracing a journey from the deepest dark to barely-there light —
        from melancholy to catharsis.
      </p>
      <div class="color-strip">
        {colors.map((c) => (
          <div class="strip-swatch" style={`background: ${c.hex};`} title={c.name}></div>
        ))}
      </div>
    </div>
    <div class="scroll-line"></div>
  </header>

  <main>
    <section id="palette" class="section">
      <div class="container">
        <div class="section-head">
          <h2 class="section-title">Palette</h2>
          <p class="section-sub">Click any hex code to copy it to your clipboard.</p>
        </div>
        <div class="color-grid">
          {colors.map((c) => (
            <ColorCard name={c.name} hex={c.hex} rgb={c.rgb} description={c.description} />
          ))}
        </div>
      </div>
    </section>

    <section id="usage" class="section">
      <div class="container">
        <div class="section-head">
          <h2 class="section-title">Where to use it</h2>
          <p class="section-sub">
            The palette suits any project that calls for introspection and atmosphere.
          </p>
        </div>
        <div class="usage-grid">
          {usages.map((u) => (
            <UsageCard title={u.title} description={u.description} />
          ))}
        </div>
      </div>
    </section>

    <section id="code" class="section">
      <div class="container">
        <div class="section-head">
          <h2 class="section-title">Use in your project</h2>
          <p class="section-sub">Copy the tokens for your preferred stack.</p>
        </div>
        <div class="code-tabs">
          <div class="tab-bar">
            <button class="tab-btn active" data-tab="css">CSS</button>
            <button class="tab-btn" data-tab="scss">SCSS</button>
            <button class="tab-btn" data-tab="tailwind">Tailwind</button>
          </div>
          <div class="tab-panels">
            <div class="tab-panel active" data-panel="css">
              <button class="copy-btn" data-copy-code="css">Copy</button>
              <pre><code>{snippets.css}</code></pre>
            </div>
            <div class="tab-panel" data-panel="scss">
              <button class="copy-btn" data-copy-code="scss">Copy</button>
              <pre><code>{snippets.scss}</code></pre>
            </div>
            <div class="tab-panel" data-panel="tailwind">
              <button class="copy-btn" data-copy-code="tailwind">Copy</button>
              <pre><code>{snippets.tailwind}</code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span class="footer-name">Mélancolique Nocturne</span>
      <span class="footer-license">GNU AGPL-3.0</span>
    </div>
  </footer>
</Layout>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 54px;
    background: rgba(13, 13, 26, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2.25rem;
  }

  .nav-links a {
    font-size: 0.82rem;
    color: var(--text-secondary);
    transition: color var(--transition);
    letter-spacing: 0.04em;
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding-top: 54px;
  }

  .hero-inner {
    text-align: center;
    max-width: 680px;
    padding: 0 2rem;
  }

  .hero-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 400;
    color: var(--catharsis);
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.9s ease-out 0.2s both;
  }

  .hero-desc {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 480px;
    margin: 0 auto 2.75rem;
    animation: fadeUp 0.9s ease-out 0.45s both;
  }

  .color-strip {
    display: flex;
    height: 5px;
    border-radius: 100px;
    overflow: hidden;
    animation: fadeUp 0.9s ease-out 0.7s both;
  }

  .strip-swatch {
    flex: 1;
    transition: flex var(--transition-slow);
  }

  .color-strip:hover .strip-swatch {
    flex: 0.55;
  }

  .color-strip:hover .strip-swatch:hover {
    flex: 2.5;
  }

  .scroll-line {
    position: absolute;
    bottom: 2.25rem;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--blue));
    animation: fadeIn 1s ease-out 1.2s both;
  }

  .section {
    padding: 6rem 0;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-head {
    margin-bottom: 2.75rem;
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }

  .section-sub {
    font-size: 0.9rem;
    color: var(--text-secondary);
    max-width: 440px;
  }

  .color-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .usage-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .code-tabs {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .tab-bar {
    display: flex;
    border-bottom: 1px solid var(--border);
    padding: 0 0.75rem;
    gap: 0.25rem;
  }

  .tab-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.7rem 0.9rem;
    cursor: pointer;
    transition: color var(--transition);
    position: relative;
    letter-spacing: 0.04em;
  }

  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform var(--transition);
  }

  .tab-btn.active {
    color: var(--text-primary);
  }

  .tab-btn.active::after {
    transform: scaleX(1);
  }

  .tab-btn:not(.active):hover {
    color: var(--text-secondary);
  }

  .tab-panel {
    display: none;
    padding: 1.5rem;
    position: relative;
  }

  .tab-panel.active {
    display: block;
  }

  .tab-panel pre {
    overflow-x: auto;
  }

  .tab-panel code {
    font-family: var(--font-mono);
    font-size: 0.83rem;
    color: var(--text-secondary);
    line-height: 1.85;
    white-space: pre;
  }

  .copy-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--accent-dim);
    border: 1px solid var(--border);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.73rem;
    padding: 0.28rem 0.7rem;
    border-radius: var(--radius-xs);
    cursor: pointer;
    transition: background var(--transition);
    letter-spacing: 0.04em;
  }

  .copy-btn:hover {
    background: rgba(155, 181, 214, 0.2);
  }

  .footer {
    border-top: 1px solid var(--border);
    padding: 2.25rem 0;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-name {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .footer-license {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (max-width: 1024px) {
    .color-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }

    .color-grid,
    .usage-grid {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>

<script define:vars={{ snippets }}>
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
      btn.classList.add('active');
      document.querySelector(`[data-panel="${tab}"]`).classList.add('active');
    });
  });

  document.querySelectorAll('.copy-btn[data-copy-code]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.copyCode;
      try {
        await navigator.clipboard.writeText(snippets[key]);
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = original; }, 1400);
      } catch {}
    });
  });
</script>
